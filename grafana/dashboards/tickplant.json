{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["tickplant", "market-data"],
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "TickPlant — Live Market Data",
  "uid": "tickplant-v1",
  "version": 1,
  "templating": { "list": [] },

  "panels": [

    {
      "id": 1,
      "title": "E2E Latency — p50 / p99 / p999 by Exchange",
      "description": "End-to-end latency from WebSocket frame received to order-book update complete (nanoseconds). Histograms use buckets: 100 ns … 100 µs.",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ns",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": false,
            "axisCenteredZero": false,
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "log", "log": 2 }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "right",
          "calcs": ["mean", "max", "last"]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (exchange, le) (rate(tickplant_e2e_latency_ns_bucket[$__rate_interval])))",
          "legendFormat": "p50  {{exchange}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (exchange, le) (rate(tickplant_e2e_latency_ns_bucket[$__rate_interval])))",
          "legendFormat": "p99  {{exchange}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.999, sum by (exchange, le) (rate(tickplant_e2e_latency_ns_bucket[$__rate_interval])))",
          "legendFormat": "p999 {{exchange}}",
          "refId": "C"
        }
      ]
    },

    {
      "id": 2,
      "title": "Message Throughput — Snapshots & Incrementals per Second",
      "description": "Rate of L2 depth messages delivered to the order-book engine, broken down by exchange and message type (snapshot = full book reset, incremental = delta update).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": false,
            "axisCenteredZero": false,
            "axisPlacement": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "right",
          "calcs": ["mean", "last"]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(tickplant_messages_total[$__rate_interval])",
          "legendFormat": "{{exchange}}  {{type}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "Book Staleness — Worst-Case per Exchange (ms)",
      "description": "Max staleness across all symbols for each exchange. Orange line = 500 ms (continuously-streaming feeds). Red line = 30 s (Binance: @depth20 only emits on book change; quiet symbols can legitimately go silent for 10–20 s).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": false,
            "axisCenteredZero": false,
            "axisPlacement": "auto",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null  },
              { "color": "orange", "value": 500   },
              { "color": "red",    "value": 30000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (exchange) (tickplant_book_staleness_ms)",
          "legendFormat": "{{exchange}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "Arbitrage Detection Rate — Signals per Second by Exchange Pair",
      "description": "Cross-exchange arbitrage opportunities detected per second (aggregated across all symbols). Stacked bars show relative contribution from each buy→sell pair.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "lineWidth": 1,
            "fillOpacity": 70,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "normal", "group": "A" },
            "axisCenteredZero": false,
            "axisPlacement": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "right",
          "calcs": ["sum", "last"]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (buy_exchange, sell_exchange) (rate(tickplant_arb_detections_total[$__rate_interval]))",
          "legendFormat": "{{buy_exchange}} → {{sell_exchange}}",
          "refId": "A"
        }
      ]
    }

  ]
}
